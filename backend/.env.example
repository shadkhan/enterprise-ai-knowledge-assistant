ENVIRONMENT=local
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/knowledge
REDIS_URL=redis://localhost:6379/0

# LLM options:
# - mock: free deterministic local answers
# - openai_mock: free OpenAI-shaped mock calls
# - openai: official OpenAI Responses API
# - openai_compatible: Chat Completions API for OpenAI-compatible hosted/local models
DEFAULT_LLM_PROVIDER=mock
INGESTION_WATCH_FOLDER=./data/ingest
INGESTION_ARCHIVE_FOLDER=./data/ingest/archive

OPENAI_API_KEY=
OPENAI_CHEAP_MODEL=gpt-4o-mini
OPENAI_PREMIUM_MODEL=gpt-4o
OPENAI_FALLBACK_TO_MOCK=true

# Optional OpenAI-compatible provider examples:
# DEFAULT_LLM_PROVIDER=openai_compatible
# OPENAI_COMPATIBLE_BASE_URL=http://host.docker.internal:11434/v1
# OPENAI_COMPATIBLE_API_KEY=ollama
# OPENAI_COMPATIBLE_CHEAP_MODEL=llama3.2:3b
# OPENAI_COMPATIBLE_PREMIUM_MODEL=llama3.1:8b
